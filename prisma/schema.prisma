generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Page {
  id        String        @id @default(cuid())
  slug      String        @unique
  title     String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  sections  PageSection[]
}

model PageSection {
  id          String   @id @default(cuid())
  pageId      String
  sectionType String
  title       String
  order       Int      @default(0)
  visible     Boolean  @default(true)
  content     String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model MenuItem {
  id          String     @id @default(cuid())
  label       String
  url         String?
  icon        String?
  description String?
  parentId    String?
  parent      MenuItem?  @relation("MenuChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children    MenuItem[] @relation("MenuChildren")
  order       Int        @default(0)
  visible     Boolean    @default(true)
  isButton    Boolean    @default(false)
  buttonStyle String?
  openInNew   Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model PartnerLogo {
  id        String   @id @default(cuid())
  name      String
  fileName  String
  order     Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
